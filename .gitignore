# Browser-safe Supabase config can be committed when it only contains the
# public project URL and anon/publishable key. Keep private variants ignored.
supabase-config.local.js
supabase-config.secret.js

# Node dependencies and package manager output.
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files and local secrets.
.env
.env.*
!.env.example
!.env.local.example
*.local
*.secret
*.secrets
secrets/

# Private key/certificate material.
*.pem
*.key
*.p12
*.pfx
*.crt

# Supabase local CLI artifacts that can contain machine-specific state.
.supabase/
